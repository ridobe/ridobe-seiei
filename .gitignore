# Exclude editor temporary files
*~

# Exclude build artifacts
*.o
*.ko
*.a
*.so
*.so.dbg
modules.order
Module.symvers

# Exclude configuration files (if not needed for reproducibility)
.config

# Exclude local build results
.tmp_versions/

# Exclude generated documentation
Documentation/DocBook/

# Exclude generated kernel headers
usr/include/

# Exclude generated kernel image
vmlinux
vmlinuz

# Exclude generated modules
modules/*

# Exclude generated .config backup
.config.old

# Add patterns for specific subdirectories if needed, e.g.,
arch/*/boot/
scripts/kconfig/

# Patterns specific to project or build system
*.patch
